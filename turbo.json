{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "DATABASE_URL",
    "NEXT_PUBLIC_APP_URL",
    "ADMIN_SECRET_TOKEN",
    "WAVE_MERCHANT_ID",
    "WAVE_WEBHOOK_SECRET",
    "OM_BASE_URL",
    "OM_CLIENT_ID",
    "OM_CLIENT_SECRET",
    "OM_MERCHANT_KEY"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
