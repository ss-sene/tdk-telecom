---
// apps/web/src/pages/index.astro
import '../styles/global.css';
import { TDK_PLANS_ARRAY } from '@tdk/config';

const BRAND = {
	name:    "TDK Telecom",
	primary: "#1A3C9F",
};

const CHECKOUT_URL = import.meta.env.PUBLIC_CHECKOUT_URL || 'http://localhost:3000/checkout';

const ADVANTAGES = [
	{
		icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" />`,
		title: "Connexion stable & rapide",
		desc:  "Débit garanti pour le streaming, les appels et le travail en ligne. Sans coupure.",
	},
	{
		icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />`,
		title: "Support local réactif",
		desc:  "Une équipe sénégalaise disponible pour vous accompagner. Par téléphone ou WhatsApp.",
	},
	{
		icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />`,
		title: "Prix transparents",
		desc:  "Pas de frais cachés. Vous payez ce que vous voyez, chaque mois, sans surprise.",
	},
	{
		icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" />`,
		title: "Paiement mobile simple",
		desc:  "Souscrivez et payez directement via Wave ou Orange Money. En moins de 2 minutes.",
	},
];
---

<html lang="fr" class="scroll-smooth">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1" />
	<link rel="preconnect" href="https://fonts.googleapis.com" />
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
	<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
	<title>{BRAND.name} — Internet Haut Débit au Sénégal</title>
	<meta name="description" content="Rejoignez le réseau TDK Telecom. Connexion stable, rapide et abordable. Payez via Wave ou Orange Money." />
</head>

<body class="min-h-screen bg-white font-[Inter,sans-serif] text-gray-900 selection:bg-[#1A3C9F] selection:text-white">

	<!-- NAV -->
	<nav class="sticky top-0 z-50 w-full border-b border-gray-100 bg-white/90 backdrop-blur-md">
		<div class="mx-auto flex max-w-6xl items-center justify-between px-5 py-3.5">

			<!-- Logo -->
			<a href="/" class="flex items-center gap-2.5">
				<img src="/logo.png" alt="TDK Telecom" width="36" height="36" class="h-9 w-auto object-contain" />
				<span class="text-lg font-black tracking-tight text-[#1A3C9F]">{BRAND.name}</span>
			</a>

			<!-- Nav desktop -->
			<div class="hidden md:flex items-center gap-6 text-sm font-semibold text-gray-600">
				<a href="#avantages" class="hover:text-[#1A3C9F] transition-colors">Avantages</a>
				<a href="#offres"    class="hover:text-[#1A3C9F] transition-colors">Offres</a>
			</div>

			<!-- CTA + hamburger -->
			<div class="flex items-center gap-3">
				<a href="#offres" class="rounded-xl bg-[#1A3C9F] px-5 py-2.5 text-sm font-bold text-white hover:bg-[#142E7B] transition-colors">
					S&apos;abonner
				</a>
				<!-- Hamburger mobile -->
				<button
					id="menu-toggle"
					type="button"
					class="md:hidden flex h-9 w-9 items-center justify-center rounded-xl border border-gray-200 text-gray-600 hover:bg-gray-50 transition-colors"
					aria-label="Ouvrir le menu"
					aria-expanded="false"
				>
					<svg id="icon-open" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
					</svg>
					<svg id="icon-close" class="h-5 w-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
					</svg>
				</button>
			</div>
		</div>

		<!-- Menu mobile -->
		<div id="mobile-menu" class="hidden md:hidden border-t border-gray-100 bg-white px-5 pb-4 pt-3 space-y-1">
			<a href="#avantages" class="block rounded-xl px-4 py-3 text-sm font-semibold text-gray-700 hover:bg-gray-50 transition-colors">Avantages</a>
			<a href="#offres"    class="block rounded-xl px-4 py-3 text-sm font-semibold text-gray-700 hover:bg-gray-50 transition-colors">Offres</a>
		</div>
	</nav>

	<main>

		<!-- HERO -->
		<section class="bg-white px-5 pt-20 pb-24 sm:pt-28 sm:pb-32 text-center">
			<div class="mx-auto max-w-3xl">
				<div class="inline-flex items-center gap-2 rounded-full border border-[#1A3C9F]/20 bg-[#1A3C9F]/5 px-4 py-1.5 text-xs font-bold text-[#1A3C9F] mb-6">
					<span class="h-1.5 w-1.5 rounded-full bg-[#2ECA50] inline-block"></span>
					Réseau actif au Sénégal
				</div>
				<h1 class="text-4xl font-black tracking-tight text-gray-900 sm:text-6xl leading-tight">
					Internet haut débit<br /><span class="text-[#1A3C9F]">partout au Sénégal.</span>
				</h1>
				<p class="mx-auto mt-6 max-w-xl text-lg leading-relaxed text-gray-500">
					Rejoignez {BRAND.name}. Connexion stable et rapide pour votre foyer.
					Payez facilement via <strong class="text-gray-700 font-semibold">Wave</strong> ou <strong class="text-gray-700 font-semibold">Orange Money</strong>.
				</p>
				<div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
					<a href="#offres" class="w-full sm:w-auto rounded-xl bg-[#1A3C9F] px-8 py-4 text-base font-bold text-white hover:bg-[#142E7B] transition-colors shadow-lg shadow-[#1A3C9F]/20">
						Voir les offres
					</a>
					<a href="#avantages" class="w-full sm:w-auto rounded-xl border border-gray-200 px-8 py-4 text-base font-semibold text-gray-700 hover:bg-gray-50 transition-colors">
						En savoir plus
					</a>
				</div>
			</div>
		</section>

		<!-- AVANTAGES -->
		<section id="avantages" class="bg-[#F9FAFB] px-5 py-20 sm:py-28">
			<div class="mx-auto max-w-6xl">
				<div class="text-center mb-14">
					<p class="text-xs font-bold uppercase tracking-widest text-[#1A3C9F] mb-2">Pourquoi TDK ?</p>
					<h2 class="text-3xl font-black text-gray-900 sm:text-4xl">Une connexion sur laquelle vous pouvez compter</h2>
				</div>

				<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
					{ADVANTAGES.map((adv) => (
						<div class="rounded-2xl bg-white p-6 shadow-sm ring-1 ring-gray-100">
							<div class="mb-4 flex h-10 w-10 items-center justify-center rounded-xl bg-[#1A3C9F]/8">
								<svg class="h-5 w-5 text-[#1A3C9F]" fill="none" viewBox="0 0 24 24" stroke="currentColor" set:html={adv.icon} />
							</div>
							<h3 class="font-bold text-gray-900 mb-1.5">{adv.title}</h3>
							<p class="text-sm leading-relaxed text-gray-500">{adv.desc}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- OFFRES -->
		<section id="offres" class="bg-white px-5 py-20 sm:py-28">
			<div class="mx-auto max-w-6xl">
				<div class="text-center mb-14">
					<p class="text-xs font-bold uppercase tracking-widest text-[#1A3C9F] mb-2">Tarifs simples</p>
					<h2 class="text-3xl font-black text-gray-900 sm:text-4xl">Choisissez votre offre</h2>
					<p class="mt-3 text-base text-gray-500">Sans engagement. Payez chaque mois via mobile money.</p>
				</div>

				<div class="mx-auto grid max-w-3xl grid-cols-1 gap-6 md:grid-cols-2">
					{TDK_PLANS_ARRAY.map((plan) => (
						<article class={`relative flex flex-col rounded-2xl p-8 ring-2 transition-all ${
							plan.isPopular
								? 'bg-white ring-[#1A3C9F] shadow-xl shadow-[#1A3C9F]/10'
								: 'bg-white ring-gray-200 shadow-sm'
						}`}>

							{/* Badge populaire */}
							{plan.isPopular && (
								<div class="absolute -top-3.5 left-1/2 -translate-x-1/2 rounded-full bg-[#1A3C9F] px-4 py-1 text-xs font-bold text-white whitespace-nowrap">
									Le plus choisi
								</div>
							)}

							<div class="flex-1">
								<h3 class="text-lg font-bold text-gray-900">{plan.name}</h3>
								<p class="mt-1 text-sm text-[#1A3C9F] font-semibold">{plan.speed}</p>

								<div class="mt-5 flex items-baseline gap-1.5">
									<span class="text-4xl font-black text-gray-900">{plan.price.toLocaleString('fr-FR')}</span>
									<span class="text-sm font-semibold text-gray-500">FCFA / mois</span>
								</div>

								<ul class="mt-6 space-y-2.5">
									{plan.features.map((feature) => (
										<li class="flex items-center gap-2.5 text-sm text-gray-600">
											<svg class="h-4 w-4 flex-none text-[#2ECA50]" fill="currentColor" viewBox="0 0 20 20">
												<path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
											</svg>
											{feature}
										</li>
									))}
								</ul>
							</div>

							<a
								href={`${CHECKOUT_URL}?plan=${encodeURIComponent(plan.name)}`}
								class={`mt-8 flex h-12 items-center justify-center rounded-xl text-sm font-bold transition-colors ${
									plan.isPopular
										? 'bg-[#1A3C9F] text-white hover:bg-[#142E7B] shadow-md shadow-[#1A3C9F]/20'
										: 'border-2 border-[#1A3C9F] text-[#1A3C9F] hover:bg-[#1A3C9F] hover:text-white'
								}`}
							>
								Souscrire maintenant
							</a>
						</article>
					))}
				</div>

				<!-- Trust badges -->
				<div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-6 text-sm text-gray-500">
					<span class="flex items-center gap-2">
						<svg class="h-4 w-4 text-[#2ECA50]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
						</svg>
						Paiement sécurisé
					</span>
					<span class="flex items-center gap-2">
						<svg class="h-4 w-4 text-[#2ECA50]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
						</svg>
						Activation rapide
					</span>
					<span class="flex items-center gap-2">
						<svg class="h-4 w-4 text-[#2ECA50]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z" />
						</svg>
						Support local disponible
					</span>
				</div>
			</div>
		</section>

	</main>

	<!-- FOOTER -->
	<footer class="border-t border-gray-100 bg-[#F9FAFB] px-5 py-12">
		<div class="mx-auto max-w-6xl">
			<div class="flex flex-col md:flex-row items-start justify-between gap-8">

				<!-- Marque -->
				<div class="space-y-3">
					<div class="flex items-center gap-2">
						<img src="/logo.png" alt="TDK Telecom" width="32" height="32" class="h-8 w-auto object-contain" />
						<span class="font-black text-[#1A3C9F]">{BRAND.name}</span>
					</div>
					<p class="text-sm text-gray-500 max-w-xs">
						Fournisseur d&apos;accès Internet au Sénégal. Connexion haut débit pour particuliers.
					</p>
				</div>

				<!-- Liens -->
				<div class="grid grid-cols-2 gap-x-16 gap-y-2 text-sm">
					<a href="#avantages" class="text-gray-500 hover:text-[#1A3C9F] transition-colors">Avantages</a>
					<a href="#offres"    class="text-gray-500 hover:text-[#1A3C9F] transition-colors">Offres</a>
					<a href={CHECKOUT_URL} class="text-gray-500 hover:text-[#1A3C9F] transition-colors">S&apos;abonner</a>
					<a href="mailto:contact@tdktelecom.sn" class="text-gray-500 hover:text-[#1A3C9F] transition-colors">Contact</a>
				</div>
			</div>

			<div class="mt-10 border-t border-gray-200 pt-6 flex flex-col sm:flex-row items-center justify-between gap-2 text-xs text-gray-400">
				<p>© {new Date().getFullYear()} {BRAND.name}. Tous droits réservés.</p>
				<p>Dakar, Sénégal</p>
			</div>
		</div>
	</footer>

</body>
</html>

<script>
	// Menu hamburger mobile
	const toggle   = document.getElementById('menu-toggle');
	const menu     = document.getElementById('mobile-menu');
	const iconOpen  = document.getElementById('icon-open');
	const iconClose = document.getElementById('icon-close');

	if (toggle && menu && iconOpen && iconClose) {
		toggle.addEventListener('click', () => {
			const isOpen = !menu.classList.contains('hidden');
			menu.classList.toggle('hidden', isOpen);
			iconOpen.classList.toggle('hidden', !isOpen);
			iconClose.classList.toggle('hidden', isOpen);
			toggle.setAttribute('aria-expanded', String(!isOpen));
		});

		// Fermer le menu au clic sur un lien
		menu.querySelectorAll('a').forEach(link => {
			link.addEventListener('click', () => {
				menu.classList.add('hidden');
				iconOpen.classList.remove('hidden');
				iconClose.classList.add('hidden');
				toggle.setAttribute('aria-expanded', 'false');
			});
		});
	}
</script>
